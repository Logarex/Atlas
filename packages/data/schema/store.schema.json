{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:atlas:schema:store",
  "title": "Atlas Store Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "status",
    "name",
    "countryCode",
    "city",
    "address",
    "coordinates",
    "openedOn",
    "officialUrl",
    "architecture",
    "hours",
    "sources",
    "lastVerifiedAt"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "storeNumber": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "status": {
      "enum": [
        "open",
        "closed",
        "relocated",
        "announced",
        "temporary"
      ]
    },
    "name": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "en",
        "fr"
      ],
      "properties": {
        "en": {
          "type": "string",
          "minLength": 1
        },
        "fr": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "countryCode": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "countryName": {
      "type": "string",
      "minLength": 1
    },
    "region": {
      "type": "string",
      "minLength": 1
    },
    "city": {
      "type": "string",
      "minLength": 1
    },
    "address": {
      "type": "string",
      "minLength": 1
    },
    "coordinates": {
      "anyOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "latitude",
            "longitude"
          ],
          "properties": {
            "latitude": {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            "longitude": {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            }
          }
        },
        {
          "type": "null"
        }
      ]
    },
    "openedOn": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "closedOn": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "officialUrl": {
      "anyOf": [
        {
          "type": "string",
          "pattern": "^https://www\\.apple\\.(?:com|com\\.cn)/(?:(?:[a-z]{2}(?:-[a-z]{2})?|[a-z]{4})/)?retail/"
        },
        {
          "type": "string",
          "pattern": "^https://web\\.archive\\.org/web/[0-9]+/https?://(?:www\\.)?apple\\.(?:com|com\\.cn)/(?:(?:[a-z]{2}(?:-[a-z]{2})?|[a-z]{4})/)?retail/"
        },
        {
          "type": "null"
        }
      ]
    },
    "architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "era",
        "typology",
        "attributes"
      ],
      "properties": {
        "era": {
          "type": "string",
          "minLength": 1
        },
        "typology": {
          "type": "string",
          "minLength": 1
        },
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "enum": [
              "yes",
              "no",
              "unknown"
            ]
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "hours": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy",
        "officialUrl"
      ],
      "properties": {
        "policy": {
          "enum": [
            "official-link-only",
            "community-verified"
          ]
        },
        "officialUrl": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^https://"
        },
        "lastVerifiedAt": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "label",
          "url",
          "license",
          "fields",
          "verifiedAt"
        ],
        "properties": {
          "type": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "verifiedAt": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      }
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "url",
          "credit",
          "license"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "credit": {
            "type": "string",
            "minLength": 1
          },
          "license": {
            "type": "string",
            "minLength": 1
          },
          "caption": {
            "type": "string"
          },
          "takenOn": {
            "type": [
              "string",
              "null"
            ],
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          }
        }
      }
    },
    "lastVerifiedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    }
  }
}
